# Copy to .dev.vars (gitignored) and fill in. Locally only this file is read; in
# production set each value with `wrangler secret put <NAME>`.
#
# Nothing here is REQUIRED to boot — the store runs with the always-on demo
# checkout, and the ADMIN PASSWORD is set in the first-run setup wizard
# (/admin/setup), stored hashed in D1.
#
# There are only TWO Worker secrets. EVERY provider key (Stripe, OpenNode,
# Lightning, Resend, Turnstile) and its config (default rail, Lightning node URLs,
# email from-address, etc.) is set in the admin dashboard — keys encrypted in the
# D1 vault, config in D1 settings. No provider env vars.
#
# `npm run provision:local` generates both of these into .dev.vars automatically,
# so you usually don't edit this file by hand.

# ── One-click deploy note (the field below is a visible LABEL, not a real secret) ──
# In the "Deploy to Cloudflare" button, SECRETS_KEK and AUTH_SECRET render as
# MASKED fields, so their placeholder hints are hidden. This first entry's NAME acts
# as a visible instruction above them; its value is unused (it just keeps the button
# from marking the field "required"). Locally, ignore it.
SET_SECRETS_KEK_AND_AUTH_SECRET_BELOW=generate_each_with__openssl_rand_base64_32

# Key-encryption key for the D1 payment-key vault. REQUIRED to store/use any
# provider key (without it the vault is dormant → demo-only). Any long random
# string; never goes in D1. Replace before storing real keys — e.g. `openssl rand -base64 32`.
SECRETS_KEK=replace_with_a_long_random_string

# Signs admin + customer sessions (magic-link tokens, session cookies). Any long
# random string, DIFFERENT from SECRETS_KEK. Needed for admin login + accounts.
AUTH_SECRET=replace_with_a_different_long_random_string

# Cloudflare Email Sending binding (optional) — only when using the 'cloudflare'
# email provider (Workers Paid plan + an onboarded sender domain). Declared in
# wrangler.jsonc as a binding, not here. Resend (the default) needs no binding —
# its API key is set in Admin → Settings → Email.
