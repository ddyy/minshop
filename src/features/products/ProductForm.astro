---
import type { Product } from './db';
import type { CategoryOption } from '../categories/db';
import { getConfig, toMajorUnits, currencyDecimals } from '../../config';

interface Props {
  action: string;
  submitLabel: string;
  product?: Product | null;
  error?: string | null;
  /** Depth-tagged categories to choose from (empty = no categories yet). */
  categoryOptions?: CategoryOption[];
  /** Ids of categories this product currently belongs to. */
  selectedCategoryIds?: number[];
  /** Show the single-image upload (true on create; edit uses the gallery). */
  showImage?: boolean;
  /** Optional form id, so out-of-tree inputs (e.g. the variants editor) can submit
      with this form via the HTML `form="..."` attribute. */
  formId?: string;
}

const {
  action,
  submitLabel,
  product = null,
  error = null,
  categoryOptions = [],
  selectedCategoryIds = [],
  showImage = true,
  formId,
} = Astro.props;
const selected = new Set(selectedCategoryIds);
// New products default to the store currency; edits keep their own.
const defaultCurrency = product?.currency ?? getConfig().currency;
const priceDecimals = currencyDecimals(defaultCurrency);
const price = product
  ? toMajorUnits(product.price_cents, product.currency).toFixed(currencyDecimals(product.currency))
  : '';
// Input increment matches the currency's precision: 0.01 (USD), 1 (JPY), 0.001 (BHD).
const priceStep = priceDecimals > 0 ? (10 ** -priceDecimals).toFixed(priceDecimals) : '1';
const inputClass =
  'mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-brand focus:outline-none';
---

<form
  method="POST"
  action={action}
  enctype="multipart/form-data"
  id={formId}
  class="max-w-lg space-y-4"
>
  {
    error && (
      <p class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
        {error}
      </p>
    )
  }

  <div>
    <label class="block text-sm font-medium" for="name">Name</label>
    <input id="name" name="name" type="text" required value={product?.name ?? ''} class={inputClass} />
  </div>

  <div>
    <label class="block text-sm font-medium" for="slug">
      Slug <span class="text-gray-400">(URL — blank to auto-generate from name)</span>
    </label>
    <input
      id="slug"
      name="slug"
      type="text"
      value={product?.slug ?? ''}
      placeholder="auto-from-name"
      class={inputClass}
    />
  </div>

  <div>
    <label class="block text-sm font-medium" for="description">Description</label>
    <textarea id="description" name="description" rows="3" class={inputClass}
      >{product?.description ?? ''}</textarea>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium" for="price">Price (USD)</label>
      <input id="price" name="price" type="number" step={priceStep} min="0" required value={price} class={inputClass} />
    </div>
    <div>
      <label class="block text-sm font-medium" for="stock">Stock</label>
      <input id="stock" name="stock" type="number" step="1" min="0" value={product?.stock ?? 0} class={inputClass} />
    </div>
  </div>

  {
    showImage && (
      <div>
        <label class="block text-sm font-medium" for="image">
          Image
        </label>
        <input id="image" name="image" type="file" accept="image/*" class="mt-1 block w-full text-sm" />
      </div>
    )
  }

  {
    categoryOptions.length > 0 && (
      <fieldset>
        <legend class="block text-sm font-medium">Categories</legend>
        <div class="mt-1 max-h-48 space-y-1 overflow-auto rounded-md border border-gray-300 p-2">
          {categoryOptions.map((c) => (
            <label
              class="flex items-center gap-2 text-sm"
              style={`padding-left:${c.depth * 16}px`}
            >
              <input
                type="checkbox"
                name="category"
                value={c.id}
                checked={selected.has(c.id)}
                class="h-4 w-4"
              />
              {c.name}
            </label>
          ))}
        </div>
      </fieldset>
    )
  }

  <label class="flex items-center gap-2 text-sm">
    <input name="active" type="checkbox" checked={product ? product.active === 1 : true} class="h-4 w-4" />
    Active (visible in storefront)
  </label>

  <input type="hidden" name="currency" value={defaultCurrency} />

  <div class="flex gap-3 pt-2">
    <button type="submit" class="rounded-md bg-brand px-5 py-2 font-medium text-white hover:bg-brand-hover">
      {submitLabel}
    </button>
    <a href="/admin/products" class="rounded-md border border-gray-300 px-5 py-2 hover:bg-gray-50">Cancel</a>
  </div>
</form>
