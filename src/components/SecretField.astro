---
// One encrypted-vault key INPUT, designed to live inside a section's form (which
// carries the single Save button). Submits the typed value as `secret:<name>`;
// leaving it blank keeps the stored value. When a value is already stored, shows an
// "Encrypted in D1" chip and a "Remove" checkbox (`clear:<name>`) to delete it on
// save. The Settings page's section handlers process those fields. When the vault
// (SECRETS_KEK) isn't set, the input is replaced with a short note.
interface Props {
  name: string; // SecretName
  label: string;
  hint?: string;
  storedInD1: boolean;
  vault: boolean;
}
const { name, label, hint, storedInD1, vault } = Astro.props;
---

<div class="flex flex-col gap-1">
  <div class="flex items-center gap-2">
    <span class="text-xs uppercase tracking-widest text-gray-400">{label}</span>
    {
      storedInD1 && (
        <span class="rounded-full bg-green-50 px-2 py-0.5 text-[0.65rem] font-medium text-green-700">
          Encrypted in D1
        </span>
      )
    }
  </div>
  {
    vault ? (
      <div class="flex flex-wrap items-center gap-3">
        <input
          type="password"
          name={`secret:${name}`}
          autocomplete="off"
          placeholder={storedInD1 ? 'Leave blank to keep' : hint}
          class="w-72 max-w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900 focus:border-brand focus:outline-none"
        />
        {storedInD1 && (
          <label class="flex items-center gap-1.5 text-xs text-gray-500">
            <input type="checkbox" name={`clear:${name}`} value="1" class="size-3.5" />
            Remove
          </label>
        )}
      </div>
    ) : (
      <span class="text-xs text-amber-700">
        Set <code>SECRETS_KEK</code> to add this key
      </span>
    )
  }
</div>
