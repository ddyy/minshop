---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import ProductForm from '../../../features/products/ProductForm.astro';
import { listCategories, buildTree, flattenTree } from '../../../features/categories/db';

const categoryOptions = flattenTree(buildTree(await listCategories(env.DB)));
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="New product" active="products">
  <a href="/admin/products" class="text-sm text-gray-500 hover:text-brand">&larr; Back to products</a>
  <h1 class="mt-4 mb-6 text-2xl font-bold">New product</h1>
  <ProductForm
    action="/api/admin/products"
    submitLabel="Create product"
    categoryOptions={categoryOptions}
    error={error}
  />
</AdminLayout>
