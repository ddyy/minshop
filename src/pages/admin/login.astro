---
export const prerender = false;
import { env } from 'cloudflare:workers';
import Layout from '../../layouts/Layout.astro';
import { verifyConfiguredTurnstile, TURNSTILE_FIELD } from '../../features/auth/turnstile';
import { signSession, verifySession } from '../../features/auth/session';
import { adminCredential } from '../../features/auth/admin';
import { getSecret } from '../../features/secrets/store';
import Turnstile from '../../features/auth/Turnstile.astro';

// Credential = the PBKDF2 hash set in D1 by the setup wizard.
const cred = await adminCredential(env.DB);
// No password set yet → nothing to log into; send them to the setup wizard (open
// during bootstrap) to create one.
if (!cred.enabled) return Astro.redirect('/admin/setup', 303);

// Sessions are signed with AUTH_SECRET (high-entropy), bound to the credential via a
// tag so rotation invalidates them. Fall back to the credential as the key only when
// AUTH_SECRET isn't set (degrades to the old behaviour rather than breaking login).
const signingKey = env.AUTH_SECRET || cred.tagSource;

const now = Date.now() / 1000;
// Already signed in → straight to the admin.
if (
  await verifySession(Astro.cookies.get('admin_session')?.value ?? null, signingKey, cred.tagSource, now)
) {
  return Astro.redirect('/admin', 303);
}

const SESSION_TTL = 7 * 24 * 3600; // 7 days
let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  // Bot challenge (if enabled in Settings): verify with the vault secret.
  const turnstileEnabled = Astro.locals.settings?.turnstileEnabled === true;
  const tsSecret = turnstileEnabled
    ? await getSecret(env.DB, 'turnstile_secret_key')
    : null;
  const tsOk = await verifyConfiguredTurnstile(
    turnstileEnabled,
    form.get(TURNSTILE_FIELD)?.toString(),
    tsSecret,
    Astro.request.headers.get('CF-Connecting-IP'),
  );
  const pwOk = await cred.verify(form.get('password')?.toString() ?? '');

  if (!tsOk) {
    error = 'Verification failed — please try again.';
  } else if (!pwOk) {
    error = 'Incorrect password.';
  } else {
    const token = await signSession(signingKey, cred.tagSource, SESSION_TTL, now);
    Astro.cookies.set('admin_session', token, {
      httpOnly: true,
      secure: Astro.url.protocol === 'https:',
      sameSite: 'lax',
      path: '/',
      maxAge: SESSION_TTL,
    });
    return Astro.redirect('/admin', 303);
  }
}
---

<Layout title="Admin login">
  <div class="mx-auto max-w-sm py-10">
    <h1 class="mb-6 text-2xl font-bold">Admin sign in</h1>

    {
      error && (
        <p class="mb-4 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700">
          {error}
        </p>
      )
    }

    <form method="POST" action="/admin/login" class="space-y-4">
      <label class="block text-sm">
        <span class="mb-1 block font-medium">Password</span>
        <input
          type="password"
          name="password"
          required
          autofocus
          autocomplete="current-password"
          class="w-full rounded-md border border-gray-200 px-3 py-2"
        />
      </label>

      <div class="flex justify-center">
        <Turnstile />
      </div>

      <button
        type="submit"
        class="w-full rounded-md bg-brand px-4 py-2.5 font-medium text-white hover:bg-brand-hover"
      >
        Sign in
      </button>
    </form>
  </div>
</Layout>
