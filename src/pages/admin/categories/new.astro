---
import { env } from 'cloudflare:workers';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import CategoryForm from '../../../features/categories/CategoryForm.astro';
import { listCategories, buildTree, flattenTree } from '../../../features/categories/db';

const parentOptions = flattenTree(buildTree(await listCategories(env.DB)));
const error = Astro.url.searchParams.get('error');
---

<AdminLayout title="New category" active="categories">
  <a href="/admin/categories" class="text-sm text-gray-500 hover:text-brand">&larr; Back to categories</a>
  <h1 class="mt-4 mb-6 text-2xl font-bold">New category</h1>
  <CategoryForm
    action="/api/admin/categories"
    submitLabel="Create category"
    parentOptions={parentOptions}
    error={error}
  />
</AdminLayout>
