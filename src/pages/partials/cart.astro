---
import { env } from 'cloudflare:workers';
import { formatPrice } from '../../config';
import { readCart, resolveCart, cartCount } from '../../features/cart/cart';
import ProductImage from '../../features/products/ProductImage.astro';

// Astro partial: renders ONLY this fragment (no surrounding document), so the
// cart drawer can fetch and inject it. Server-rendered, so pricing/stock still
// come from D1 — the drawer holds no client-side cart state.
export const partial = true;
export const prerender = false;

const cart = readCart(Astro.cookies);
const { lines, subtotalCents } = await resolveCart(env.DB, cart);
const count = cartCount(cart);
---

<div data-cart-count={count}>
  {
    lines.length === 0 ? (
      <p class="py-10 text-center text-sm text-gray-500">
        Your cart is empty.
      </p>
    ) : (
      <Fragment>
        <ul class="divide-y divide-line">
          {lines.map((l) => (
            <li class="flex gap-4 py-4">
              <a href={`/product/${l.product.slug}`} class="shrink-0">
                <ProductImage
                  imageKey={l.product.image_key}
                  alt=""
                  class="h-16 w-16 rounded object-cover"
                />
              </a>
              <div class="flex flex-1 flex-col">
                <a href={`/product/${l.product.slug}`} class="text-sm leading-snug hover:text-brand">
                  {l.product.name}
                </a>
                {(l.variant || l.extras.length > 0) && (
                  <span class="mt-0.5 text-xs text-gray-500">
                    {[l.variant?.label, ...l.extras.map((e) => e.label)].filter(Boolean).join(' · ')}
                  </span>
                )}
                <span class="mt-1 text-xs tabular-nums text-gray-500">
                  {formatPrice(l.unitPriceCents)}
                </span>
                <div class="mt-auto flex items-center gap-4 pt-2">
                  <form method="POST" action="/api/cart" class="flex items-center gap-2">
                    <input type="hidden" name="_action" value="update" />
                    <input type="hidden" name="key" value={l.key} />
                    <input
                      type="number"
                      name="qty"
                      min="0"
                      max="99"
                      value={l.qty}
                      aria-label="Quantity"
                      class="w-12 border-b border-line bg-transparent py-0.5 text-center text-sm tabular-nums focus:border-brand focus:outline-none"
                    />
                    <button
                      type="submit"
                      class="text-xs uppercase tracking-widest text-gray-400 hover:text-brand"
                    >
                      Update
                    </button>
                  </form>
                  <form method="POST" action="/api/cart">
                    <input type="hidden" name="_action" value="remove" />
                    <input type="hidden" name="key" value={l.key} />
                    <button
                      type="submit"
                      class="text-xs uppercase tracking-widest text-gray-400 hover:text-red-600"
                    >
                      Remove
                    </button>
                  </form>
                </div>
              </div>
              <span class="shrink-0 text-sm tabular-nums">{formatPrice(l.lineTotalCents)}</span>
            </li>
          ))}
        </ul>

        <div class="mt-6 border-t border-line pt-4">
          <div class="flex items-center justify-between">
            <span class="text-xs uppercase tracking-widest text-gray-500">Subtotal</span>
            <span class="text-lg tabular-nums">{formatPrice(subtotalCents)}</span>
          </div>
          <a
            href="/express"
            class="mt-4 block w-full rounded-md bg-brand px-6 py-3 text-center text-sm font-medium uppercase tracking-wider text-white hover:bg-brand-hover"
          >
            Checkout
          </a>
          <a
            href="/cart"
            class="mt-3 block text-center text-xs uppercase tracking-widest text-gray-400 hover:text-brand"
          >
            View full cart
          </a>
        </div>
      </Fragment>
    )
  }
</div>
