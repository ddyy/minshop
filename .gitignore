# Dependencies (root + mcp/ subproject — non-anchored, matches at any depth)
node_modules/

# Build output
dist/
.astro/
.output/

# Cloudflare / Wrangler local state (also covers mcp/.wrangler, mcp/.dev.vars)
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example

# Per-instance provisioning artifacts (scripts/provision-cf.sh)
.instances/
wrangler.jsonc.bak
# Per-instance deploy config: real ids/names live here, never published.
# The clean templates are *.template.jsonc; provision-cf.sh renders these.
/wrangler.jsonc
/mcp/wrangler.jsonc

# Environment & local overrides
.env
.env.*
*.local

# Claude Code — local, machine-specific settings (project settings.json stays tracked)
.claude/settings.local.json

# Tooling artifacts
.playwright-mcp/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
