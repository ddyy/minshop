# Dependencies (root + mcp/ subproject — non-anchored, matches at any depth)
node_modules/

# Build output
dist/
.astro/
.output/

# Cloudflare / Wrangler local state (also covers mcp/.wrangler, mcp/.dev.vars)
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example

# Per-instance provisioning artifacts (scripts/provision-cf.sh)
.instances/
wrangler.jsonc.bak
# NOTE: /wrangler.jsonc is now COMMITTED (free-plan default + Deploy-button config,
# with a placeholder database_id). provision-cf.sh renders instance ids over it and
# restores it on exit. Keep real deployed-instance configs OUTSIDE the repo.
/mcp/wrangler.jsonc

# Environment & local overrides
.env
.env.*
*.local

# Claude Code — local, machine-specific settings (project settings.json stays tracked)
.claude/settings.local.json

# Tooling artifacts
.playwright-mcp/
coverage/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor cruft
.DS_Store
Thumbs.db
